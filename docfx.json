{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "./src/DotKernel",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api",
      "filter": "docfx/filter.yml",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["index.md", "toc.yml"]
      },
      {
        "files": ["**/*.{md,yml}"],
        "src": "docs",
        "dest": "docs"
      },
      {
        "files": ["**/*.{md,yml}"],
        "src": "demo",
        "dest": "demo"
      },
      {
        "files": ["**/*.yml"],
        "src": "api",
        "dest": "api"
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "docfx/template"],
    "globalMetadata": {
      "_appName": "DotKernel",
      "_appTitle": "DotKernel Documentation",
      "_appBasePath": "/DotKernel/",
      "_enableSearch": true,
      "pdf": false,
      "_appFooter": "© DotKernel contributors",
      "_gitContribute": {
        "repo": "https://github.com/0use-TE/DotKernel",
        "branch": "main"
      }
    }
  }
}
