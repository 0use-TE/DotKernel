<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Border.chat-shell">
    <Setter Property="Background" Value="#161B26"/>
    <Setter Property="BorderBrush" Value="#2A3142"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="14"/>
  </Style>

  <Style Selector="Border.sidebar">
    <Setter Property="Background" Value="#12161F"/>
    <Setter Property="BorderBrush" Value="#2A3142"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="14"/>
  </Style>

  <Style Selector="Border.bubble-user">
    <Setter Property="Background" Value="#3B6EF5"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="MaxWidth" Value="520"/>
  </Style>

  <Style Selector="Border.bubble-assistant">
    <Setter Property="Background" Value="#232A38"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="MaxWidth" Value="520"/>
  </Style>

  <Style Selector="Border.bubble-error">
    <Setter Property="Background" Value="#4A2328"/>
    <Setter Property="BorderBrush" Value="#C94C5E"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="MaxWidth" Value="520"/>
  </Style>

  <Style Selector="Border.confirm-card">
    <Setter Property="Background" Value="#1A1F2B"/>
    <Setter Property="BorderBrush" Value="#B45309"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="14"/>
    <Setter Property="Padding" Value="14"/>
  </Style>

  <Style Selector="Border.confirm-args">
    <Setter Property="Background" Value="#0F141D"/>
    <Setter Property="BorderBrush" Value="#334155"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="10"/>
  </Style>

  <Style Selector="Border.confirm-resolved-allow">
    <Setter Property="Background" Value="#14231A"/>
    <Setter Property="BorderBrush" Value="#166534"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="10,8"/>
  </Style>

  <Style Selector="Border.confirm-resolved-deny">
    <Setter Property="Background" Value="#2A1418"/>
    <Setter Property="BorderBrush" Value="#991B1B"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="10,8"/>
  </Style>

  <Style Selector="Border.icon-badge">
    <Setter Property="Width" Value="32"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Background" Value="#2A2112"/>
    <Setter Property="Padding" Value="8"/>
  </Style>

  <Style Selector="Button.allow-button">
    <Setter Property="MinWidth" Value="96"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="Background" Value="#14532D"/>
    <Setter Property="Foreground" Value="#DCFCE7"/>
  </Style>

  <Style Selector="Button.deny-button">
    <Setter Property="MinWidth" Value="96"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="Background" Value="#3F1D24"/>
    <Setter Property="Foreground" Value="#FECACA"/>
  </Style>

  <Style Selector="Button.ghost-button">
    <Setter Property="Background" Value="#1E293B"/>
    <Setter Property="Foreground" Value="#CBD5E1"/>
    <Setter Property="Padding" Value="14,8"/>
  </Style>

  <Style Selector="TextBlock.bubble-text">
    <Setter Property="Foreground" Value="#E8EDF7"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="22"/>
  </Style>

  <Style Selector="TextBlock.role-label">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Opacity" Value="0.65"/>
    <Setter Property="Margin" Value="4,0,0,4"/>
  </Style>

  <Style Selector="Button.send-button">
    <Setter Property="MinWidth" Value="108"/>
    <Setter Property="Height" Value="40"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="16,8"/>
  </Style>

  <Style Selector="Border.zone-card">
    <Setter Property="Background" Value="#171D28"/>
    <Setter Property="BorderBrush" Value="#2B3548"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="12"/>
  </Style>

  <Style Selector="Border.zone-alert">
    <Setter Property="Background" Value="#422006"/>
    <Setter Property="BorderBrush" Value="#F59E0B"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <Style Selector="Border.activity-feed">
    <Setter Property="Background" Value="#10151E"/>
    <Setter Property="BorderBrush" Value="#273043"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
  </Style>

  <Style Selector="Border.status-chip">
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Background" Value="#1E293B"/>
  </Style>

  <Style Selector="Border.agv-badge">
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Background" Value="#312E81"/>
  </Style>

  <Style Selector="Border.metric-icon">
    <Setter Property="Width" Value="24"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="5"/>
  </Style>
</Styles>
