<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DotKernel.AvaExample.ViewModels"
             xmlns:views="using:DotKernel.AvaExample.Views"
             xmlns:mv="using:MarkView.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="DotKernel.AvaExample.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="#0E1117">

  <Grid ColumnDefinitions="*,480" Margin="20">
    <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="14">
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="DotKernel Agent" FontSize="26" FontWeight="Bold" Foreground="#F3F6FC"/>
          <TextBlock Text="多轮调度 · 流式对话 · 数字孪生联动" Opacity="0.65" FontSize="13"/>
        </StackPanel>
        <Border Grid.Column="1" Padding="10,6" CornerRadius="20" Background="#1A2233" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="#4ADE80"/>
            <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" FontSize="12"/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1" Classes="chat-shell" Padding="16">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.DataTemplates>
              <DataTemplate DataType="vm:ChatLineViewModel">
                <Panel Margin="0,0,0,14">
                  <StackPanel HorizontalAlignment="Right" IsVisible="{Binding IsUser}">
                    <TextBlock Text="{Binding Role}" Classes="role-label" HorizontalAlignment="Right"/>
                    <Border Classes="bubble-user">
                      <TextBlock Text="{Binding Content}" Classes="bubble-text"/>
                    </Border>
                  </StackPanel>

                  <StackPanel HorizontalAlignment="Left" IsVisible="{Binding !IsUser}">
                    <TextBlock Text="{Binding Role}" Classes="role-label"/>
                    <Border Classes="bubble-assistant" IsVisible="{Binding !IsError}">
                      <Panel>
                        <mv:MarkdownViewer Markdown="{Binding Content}"
                                           Classes="chat-markdown"
                                           IsVisible="{Binding UseMarkdown}"/>
                        <TextBlock Text="{Binding Content}" Classes="bubble-text"
                                   IsVisible="{Binding !UseMarkdown}"/>
                      </Panel>
                    </Border>
                    <Border Classes="bubble-error" IsVisible="{Binding IsError}">
                      <TextBlock Text="{Binding Content}" Classes="bubble-text"/>
                    </Border>
                  </StackPanel>
                </Panel>
              </DataTemplate>
            </ItemsControl.DataTemplates>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="2" Background="#12161F" BorderBrush="#2A3142" BorderThickness="1" CornerRadius="12" Padding="4">
        <TextBox Text="{Binding InputText}"
                 PlaceholderText="描述产线任务，AI 将多轮调用工具并驱动右侧孪生面板"
                 AcceptsReturn="True"
                 MinHeight="84"
                 TextWrapping="Wrap"
                 Background="Transparent"
                 BorderThickness="0"/>
      </Border>

      <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Path Data="{StaticResource IconPulse}" Width="14" Height="14" Stretch="Uniform"
                Stroke="#7DD3FC" StrokeThickness="1.4" Opacity="0.8"/>
          <TextBlock Text="流式输出" Opacity="0.7" FontSize="12"/>
          <TextBlock Text="输出中..." FontSize="12" Foreground="#7DD3FC" IsVisible="{Binding IsStreaming}"/>
          <TextBlock Text="就绪" FontSize="12" Foreground="#86EFAC" IsVisible="{Binding !IsStreaming}"/>
        </StackPanel>
        <Button Grid.Column="1" Command="{Binding ClearCommand}" Classes="ghost-button" Height="40">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconReset}" Width="14" Height="14" Stretch="Uniform"
                  Stroke="#94A3B8" StrokeThickness="1.4"/>
            <TextBlock Text="重置孪生" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Grid.Column="2" Command="{Binding SendCommand}" Classes="accent send-button">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="{StaticResource IconSend}" Width="14" Height="14" Stretch="Uniform"
                  Stroke="White" StrokeThickness="1.4"/>
            <TextBlock Text="发送" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>
    </Grid>

    <Border Grid.Column="1" Margin="18,0,0,0" Classes="sidebar" Padding="14">
      <views:TwinPanelView DataContext="{Binding}"/>
    </Border>
  </Grid>
</UserControl>
